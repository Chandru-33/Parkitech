<section class="page-section">
  <h1>Booking confirmed</h1>

  <div class="card">
    <h2>Payment receipt</h2>
    <% if (typeof message !== 'undefined' && message) { %>
    <div class="alert" style="background: #e8f5e9; border-color: #4caf50; margin-bottom: 1rem;">
      <%= message %>
    </div>
    <% } %>
    <p><strong>Total paid:</strong> ₹<%= (amount || 0).toFixed(2) %></p>
    <p><strong>Platform commission (<%= (commissionPercent || 10) %>%):</strong> ₹<%= (commission || 0).toFixed(2) %></p>
    <p><strong>Credited to client:</strong> ₹<%= (clientAmount || 0).toFixed(2) %></p>
  </div>

  <a href="/dashboard" class="btn primary">Back to Dashboard</a>
  <a href="/user/search" class="btn ghost">Find more parking</a>
</section>
